import os
import pandas as pd
import matplotlib.pyplot as plt

# Define the file path
file_path = 'titanic.csv'

# Check if the file exists
if os.path.isfile(file_path):
    # Read the CSV file
    df = pd.read_csv(file_path)

    # Count the number of survived and died passengers
    survived = len(df[df['Survived'] == 1])
    died = len(df[df['Survived'] == 0])

    # Plot a bar graph
    plt.bar(['Survived', 'Died'], [survived, died])
    plt.xlabel('Status')
    plt.ylabel('Count')
    plt.title('Survived and Died Passengers')
    plt.savefig('output.png')

    print("Task completed. The graph has been saved as output.png.")
else:
    print("The file 'titanic.csv' was not found in the current directory.")
