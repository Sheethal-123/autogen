import csv

# Open the CSV file
with open('data.csv', 'r') as file:
    # Create a CSV reader
    reader = csv.reader(file)
    
    # Print the headers
    headers = next(reader)
    print("Headers:", headers)
    
    # Print the rows
    for i, row in enumerate(reader):
        print(f"Row {i+1}: {row}")

print("Task completed.")
